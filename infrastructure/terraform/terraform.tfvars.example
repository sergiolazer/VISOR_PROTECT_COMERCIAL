aws_region   = "sa-east-1"
project_name = "visor-protect"
environment  = "production"

github_org  = "tu-org"
github_repo = "VISOR_PROTECT_COMERCIAL"

cors_origin = "https://app.tudominio.com.br"

# ECS Fargate — costo optimizado
ecs_cpu           = "256"
ecs_memory        = "512"
ecs_desired_count = 1
redis_node_type   = "cache.t4g.micro"

alert_latency_threshold_ms = 200

# Primer apply: false. Tras docker push a ECR → true (ECS Fargate + ALB).
enable_ecs = false

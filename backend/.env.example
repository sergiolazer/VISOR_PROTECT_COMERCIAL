PORT=3001
CORS_ORIGIN=http://localhost:5173
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/visor_protect?retryWrites=true&w=majority
JWT_SECRET=cambiar-por-secreto-seguro-en-produccion
JWT_EXPIRES_IN=24h
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# Producción cross-origin (app.dominio.com → api.dominio.com):
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
CHAT_HISTORY_LIMIT=50
CHAT_MESSAGE_TTL_SECONDS=604800
FEED_HISTORY_LIMIT=50
API_PUBLIC_URL=http://localhost:3001
MEDIA_URL_EXPIRES_IN_SECONDS=86400
MAX_UPLOAD_SIZE_BYTES=5242880
TRUSTED_IMAGE_DOMAINS=res.cloudinary.com,localhost,127.0.0.1
# Cloudinary (producción — si no se configura, usa almacenamiento local con URLs firmadas)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
LOCAL_UPLOAD_DIR=uploads
MONGODB_CHANGE_STREAM=false
# Redis Pub/Sub — escalado horizontal de alertas entre instancias Socket.io
# REDIS_ENABLED=true
# REDIS_URL=redis://localhost:6379
# INSTANCE_ID=node-1
# Telemetría de rechazos por filtro (debug en consola; persistir en alert_filter_logs)
# ALERT_FILTER_TELEMETRY_DEBUG=true
# ALERT_FILTER_TELEMETRY_PERSIST=true
# Mercado Pago — suscripción mensual (Brasil)
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# MERCADOPAGO_WEBHOOK_SECRET=...   # Tus integraciones → Webhooks → revelar firma
# SUBSCRIPTION_PRICE_BRL=49.90
# FRONTEND_URL=http://localhost:5173
NODE_ENV=development
